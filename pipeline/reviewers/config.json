{
  "schema_version": "1.0",
  "backbones": {
    "codex": {
      "cli": "codex",
      "model": "gpt-5.5",
      "reasoning_effort": "high",
      "invocation_wrapper": "scripts/lib/invoke_codex.sh"
    },
    "gemini": {
      "cli": "gemini",
      "model": "gemini-3.1-pro-preview",
      "invocation_wrapper": "scripts/lib/invoke_gemini.sh"
    }
  },
  "randomized_assignment": true,
  "deterministic_seed_strategy": "seed = round_number; persona_index_mod_2 + uniform[0,1)*persona_count",
  "fallback_order": ["primary_backbone", "alternate_backbone", "cached_output", "REVIEWER_DEFERRED"],
  "rate_limit_handling": {
    "on_codex_429": "switch_persona_to_gemini",
    "on_gemini_429": "switch_persona_to_codex",
    "on_both_429": "use_cached_or_defer"
  },
  "cache_path": "runs/reviewer_cache/",
  "anonymization": {
    "enforced": true,
    "forbidden_names_file": "pipeline/reviewers/FORBIDDEN_TARGET_NAMES.txt",
    "id_format": "candidate_{rank:03d}"
  }
}
