# Reference PDFs (kept locally, too large for git)
references/*.pdf

# Evaluator's expected answer — sensitive, never push to public remote
evaluator/expected_answer.json
evaluator/expected_thresholds.json

# Claude / humanize cache
.humanize/
.cache/

# Python
__pycache__/
*.pyc
*.pyo
.ipynb_checkpoints/
.pytest_cache/
venv/
.venv/

# R
.Rhistory
.RData
.Rproj.user/

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/

# Secrets
.env
.env.local
*.key
*.pem

# Logs
*.log
logs/

# Large intermediate data (selectively re-add as needed)
data/raw/
data/intermediate/

# Per-round runtime artifacts (regenerated by run_pipeline.sh)
runs/
proposals/
diagnostics/
reviews/

# Per-round derived analysis outputs (regenerated by pipeline scripts)
pipeline/anti_bias/_results_*.json
pipeline/scoring/_scores_*.tsv
pipeline/universe/candidate_universe.tsv
pipeline/universe/universe_build_diagnostics.json
